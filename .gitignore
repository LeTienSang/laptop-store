# Dependency directories (Thư viện)
node_modules/
jspm_packages/

# Build outputs (Sản phẩm sau khi đóng gói)
dist/
build/
.cache/

# Environment variables (Cực kỳ quan trọng: Không push mật khẩu/key lên Git)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.example

# Debug logs (File nhật ký lỗi)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Editor-specific (Cấu hình riêng của các trình soạn thảo)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# OS-specific (File rác của hệ điều hành)
.DS_Store
Thumbs.db

# Database specific (Nếu bạn có file backup SQL hoặc DB cục bộ)
*.bak
*.sql
*.mdf
*.ldf

# Frontend specific (Vite, Next.js, etc.)
.eslintcache

